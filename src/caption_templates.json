# ----------------------------------------------------------
# 🎯 MAIN PROCESS FUNCTION (UI Compatible)
# ----------------------------------------------------------
def rewrite_caption(caption: str, tone: str = "professional", rewrite_type="simple"):
    """
    Returns the EXACT structure that frontend expects.
    """

    if not caption.strip():
        return {"error": "Caption empty"}

    lang = detect_language(caption)
    tone = tone.lower().strip()

    if tone not in TONE_LIBRARY[lang]:
        tone = "professional"

    prefix = TONE_LIBRARY[lang][tone]["prefix"]
    suffix = TONE_LIBRARY[lang][tone]["suffix"]
    manual_tags = TONE_LIBRARY[lang][tone]["hashtags"]

    base = clean_caption(caption)

    # ------------------------
    # AI Rewrite
    # ------------------------
    system = "You rewrite captions while keeping meaning same. No explanation."
    user = f"""
Rewrite this in {tone} style & {rewrite_type} formatting.
Language: {"Bangla" if lang=="bn" else "English"}

Caption:
{base}
"""

    try:
        rewritten = clean_caption(ask_ai(system, user))
    except:
        rewritten = base

    # Add tone prefix + suffix
    final_caption = f"{prefix}{rewritten}{suffix}"

    # ------------------------
    # Emotion
    # ------------------------
    try:
        emo_org = detect_emotion(base)
        emo_new = detect_emotion(final_caption)
    except:
        emo_org = emo_new = {"emotion": "neutral"}

    # ------------------------
    # Fake / Real
    # ------------------------
    try:
        fr_org = detect_fake(base)
        fr_new = detect_fake(final_caption)
    except:
        fr_org = fr_new = {"real": 50, "fake": 50}

    # ------------------------
    # SEO
    # ------------------------
    try:
        seo_org = compute_seo_score(base)
        seo_new = compute_seo_score(final_caption)
    except:
        seo_org = {"score": 40, "grade": "C", "suggestions": []}
        seo_new = {"score": 45, "grade": "C", "suggestions": []}

    # ------------------------
    # AI Hashtags
    # ------------------------
    try:
        auto_tags = generate_hashtags(final_caption, tone=tone, top_n=10)
        hashtags = manual_tags + " " + " ".join(auto_tags)
    except:
        hashtags = manual_tags

    # ------------------------
    # RETURN — 100% UI compatible
    # ------------------------
    return {
        "optimized_caption": final_caption,
        "emotion": {
            "original": emo_org,
            "optimized": emo_new
        },
        "seo": {
            "score": seo_new["score"],
            "difference": seo_new["score"] - seo_org["score"],
            "suggestions": seo_new.get("suggestions", [])
        },
        "fake_real": {
            "real": fr_new.get("real", 0),
            "fake": fr_new.get("fake", 0)
        },
        "hashtags": hashtags
    }
