# ----------------------------------------------------------
# 🔍 LANGUAGE DETECT
# ----------------------------------------------------------
def detect_language(text: str):
    bn = sum(1 for ch in text if 2432 <= ord(ch) <= 2559)
    return "bn" if bn > 10 else "en"


# ----------------------------------------------------------
# ✨ CLEAN CAPTION
# ----------------------------------------------------------
def clean_caption(text: str) -> str:
    if not text:
        return ""
    text = text.replace("\r", "")
    text = re.sub(r"[ \t]+", " ", text)
    return text.strip()


